%sql
-- Pick the latest CA story and generate a comprehensive UPSC Mains analysis using Sonnet 4.6
SELECT
  s.title,
    s.date,
      s.gs_papers,
        s.topic_cluster,
          ai_query(
                'databricks-claude-sonnet-4-6',
                    CONCAT(
                              'You are a UPSC CSE Mains expert. Analyze this Current Affairs story for UPSC relevance:\n\n',
                                    'Title: ', s.title, '\n',
                                          'Topic: ', s.topic_cluster, '\n',
                                                'GS Papers: ', COALESCE(s.gs_papers, 'N/A'), '\n',
                                                      'Keywords: ', COALESCE(s.keywords, 'N/A'), '\n\n',
                                                            'Provide:\n1. GS Paper Mapping (which papers & why)\n2. Key UPSC Keywords (5-7)\n3. 250-word Model Answer suitable for Mains GS\n4. Probable Prelims angle (1 MCQ stem)'
                    ),
                        modelParameters => named_struct('max_tokens', 1000, 'temperature', 0.3)
          ) AS sonnet_analysis
          FROM upsc_catalog.rag.stories s
          ORDER BY s.date DESC
          LIMIT 1
                    )
          )g